@model IEnumerable<TaskBoard.Models.Task>

<h1>Tasks</h1>

<p>
    <a asp-action="Create">Create New Task</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Title</th>
            <th>Description</th>
            <th>Created On</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>@item.Title</td>
            <td>@item.Description</td>
            <td>@item.CreatedOn</td>
        </tr>
}
    </tbody>
</table>
